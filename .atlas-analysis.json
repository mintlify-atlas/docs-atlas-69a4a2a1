  "keyFeatures": [
    "Commands - Entry-point prompts for workflows invoked with /command-name",
    "Subagents - Custom agents with specialized tools, permissions, and models",
    "Skills - Reusable knowledge and workflows with progressive disclosure",
    "Hooks - Deterministic scripts for lifecycle events",
    "MCP Servers - Model Context Protocol connections to external tools",
    "Settings - Hierarchical configuration system",
    "Memory - Persistent context via CLAUDE.md files",
    "Orchestration Patterns - Command → Agent → Skill architecture"
  ],
  "publicApiSurface": [
    "/.claude/commands/<name>.md - Custom command definitions",
    "/.claude/agents/<name>.md - Custom subagent definitions",
    "/.claude/skills/<name>/SKILL.md - Skill definitions",
    "/.claude/hooks/ - Hook scripts and configuration",
    "/.claude/settings.json - Project settings",
    "/.mcp.json - MCP server configuration",
    "/CLAUDE.md - Project memory file",
    "/weather-orchestrator - Example orchestration command",
    "/weather-agent - Example subagent with preloaded skills",
    "/weather-fetcher - Example agent skill (preloaded)",
    "/weather-svg-creator - Example standalone skill",
    "Task tool - Subagent invocation API",
    "Skill tool - Skill invocation API",
    "String substitutions - $ARGUMENTS, $N, ${CLAUDE_SESSION_ID}",
    "Dynamic context injection - !`command` syntax",
    "Frontmatter fields - YAML configuration for commands/agents/skills"
  ]
